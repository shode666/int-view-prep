{
  "name": "prep-pair-prog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Node.js pair-programming interview prep kit — katas, REST API, async/streams drills",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:katas": "vitest run tests/katas",
    "test:api": "vitest run tests/api",
    "test:async": "vitest run tests/async",
    "test:solutions": "vitest run --config vitest.solutions.config.ts",
    "dev": "tsx watch src/api/server.ts",
    "dev:solutions": "tsx watch solutions/api/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
